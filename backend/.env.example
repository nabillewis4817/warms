# Warm's - Backend (Django)
#
# Copie ce fichier en ".env" puis adapte les valeurs.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (recommandé)
# Exemple:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/warms
DATABASE_URL=postgres://postgres:postgres@localhost:5432/warms

# IA provider - Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# CORS pour front web local
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:51155,http://127.0.0.1:51155
