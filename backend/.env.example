# Warm's - Backend (Django)
#
# Copie ce fichier en ".env" puis adapte les valeurs.
# Ne JAMAIS committer le ".env" réel (il est dans .gitignore) ni mettre
# un vrai secret dans CE fichier .env.example (il est versionné dans git).

DJANGO_DEBUG=True
# Génère une vraie clé avec:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Une clé différente DOIT être utilisée en production (jamais réutiliser
# celle du dev) : elle signe aussi les tokens JWT.
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (recommandé). Remplace USER/PASSWORD/HOST par les tiens.
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/warms
DATABASE_URL=postgres://postgres:CHANGE_ME@localhost:5432/warms

# IA provider - Anthropic Claude (optionnel : sans clé, le Chat IA
# fonctionne avec un moteur de règles gratuit, voir ia_shared/views.py)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Recherche web (Google Custom Search) - écran "Recherche IA"
# Clé API: console.cloud.google.com (active "Custom Search API")
# CSE ID: programmablesearchengine.google.com (configuré pour tout le web)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# CORS pour front web local (en prod: mettre le vrai domaine du front,
# ex: https://admin.cabinet.fr)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:51155,http://127.0.0.1:51155

# Redis (couche temps réel Channels). Laisser vide en dev (une couche en
# mémoire locale suffit pour un seul worker). En production avec plusieurs
# workers Daphne, définir une vraie URL, ex: redis://localhost:6379/0
REDIS_URL=

# Email (réinitialisation de mot de passe, etc.). Laisser vide en dev: les
# emails sont alors affichés dans la console au lieu d'être réellement
# envoyés. En production, fournir un vrai compte SMTP.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@wams-dentaire.com

# Notifications push mobiles (Firebase Cloud Messaging). Laisser vide tant
# que le projet Firebase n'existe pas : le push est alors désactivé sans
# erreur. Chemin vers le fichier JSON de clé de compte de service Firebase
# (console Firebase > Paramètres du projet > Comptes de service > Générer
# une nouvelle clé privée). Ne JAMAIS committer ce fichier JSON dans git.
FIREBASE_CREDENTIALS_PATH=

# --- Variables supplémentaires UNIQUEMENT pour la production ---
# (sans effet tant que DJANGO_DEBUG=True)
# CSRF_TRUSTED_ORIGINS=https://admin.cabinet.fr,https://api.cabinet.fr
# SECURE_SSL_REDIRECT=True
